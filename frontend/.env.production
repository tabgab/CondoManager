# CondoManager Frontend Production Environment
# Copy this file to .env.production and fill in your actual values
# DO NOT commit .env.production to git!
# =============================================================================
# API CONFIGURATION
# =============================================================================
# Backend API URL - from Render deployment
# Format: https://your-backend.onrender.com/api/v1
VITE_API_URL=https://condomanager-backend.onrender.com

# WebSocket URL - wss for production (secure)
# Format: wss://your-backend.onrender.com/ws
VITE_WS_URL=wss://condomanager-backend.onrender.com/ws

# =============================================================================
# PWA CONFIGURATION
# =============================================================================
# Enable Progressive Web App features
VITE_PWA_MODE=true

# App name (displayed in install prompt)
VITE_APP_NAME=CondoManager

# App short name (for home screen icon)
VITE_APP_SHORT_NAME=Condo

# Theme color
VITE_THEME_COLOR=#0f172a

# =============================================================================
# TELEGRAM BOT
# =============================================================================
# Bot username for Telegram integration
# Get from BotFather: https://t.me/botfather
VITE_TELEGRAM_BOT_USERNAME=condomanagertest_bot

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable push notifications
VITE_ENABLE_PUSH_NOTIFICATIONS=true

# Enable service worker (for offline support)
VITE_ENABLE_SERVICE_WORKER=true

# =============================================================================
# DEBUGGING
# =============================================================================
# Disable in production
VITE_DEBUG=false

# Sentry DSN for error tracking (optional)
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
